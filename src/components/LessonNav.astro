---
import { getLessonBySlug } from '../data/curriculum';

export interface Props {
  prev: string | null;
  next: string | null;
}
const { prev, next } = Astro.props;
const prevLesson = prev ? getLessonBySlug(prev) : null;
const nextLesson = next ? getLessonBySlug(next) : null;
---

<nav class="lesson-nav" aria-label="레슨 이동">
  {prevLesson ? (
    <a href={import.meta.env.BASE_URL + prevLesson.slug.replace(/^\//, '')} class="lesson-nav-btn prev">
      <span class="nav-arrow">←</span>
      <span class="nav-info">
        <span class="nav-label">이전 레슨</span>
        <span class="nav-title">{prevLesson.title}</span>
      </span>
    </a>
  ) : <div></div>}

  {nextLesson ? (
    <a href={import.meta.env.BASE_URL + nextLesson.slug.replace(/^\//, '')} class="lesson-nav-btn next">
      <span class="nav-arrow">→</span>
      <span class="nav-info">
        <span class="nav-label">다음 레슨</span>
        <span class="nav-title">{nextLesson.title}</span>
      </span>
    </a>
  ) : <div></div>}
</nav>
