---
import { weeks, lessons } from '../data/curriculum';

export interface Props {
  currentSlug: string;
  isMobile?: boolean;
}
const { currentSlug, isMobile = false } = Astro.props;
const totalLessons = lessons.length;
const sidebarClass = isMobile ? 'sidebar-mobile' : 'sidebar';
---

<nav class={sidebarClass} id={isMobile ? 'mobileSidebar' : 'sidebar'} aria-label="커리큘럼 목차">
  <div class="sidebar-progress-wrap" data-total={totalLessons}>
    <div class="sidebar-progress-label">
      <span>전체 진행률</span>
      <span class="sidebar-pct" id={isMobile ? 'mobilePct' : 'sidebarPct'}>0%</span>
    </div>
    <div class="sidebar-progress-track">
      <div class="sidebar-progress-fill" id={isMobile ? 'mobileProgressFill' : 'sidebarProgressFill'} style="width:0%"></div>
    </div>
  </div>

  {weeks.map((week) => (
    <div class={`sidebar-week w${week.number}`}>
      <div class="sidebar-week-header">
        <span class="sidebar-week-dot"></span>
        <span>{week.number}주차 — {week.title}</span>
      </div>
      {week.lessons.map((lesson) => (
        <a
          href={import.meta.env.BASE_URL + lesson.slug.replace(/^\//, '')}
          class={`sidebar-lesson ${lesson.slug === currentSlug ? 'active' : ''}`}
          data-lesson-id={lesson.id}
        >
          <span
            class="sidebar-check"
            data-check={lesson.id}
            role="checkbox"
            aria-label={`${lesson.title} 완료 표시`}
            tabindex="0"
          ></span>
          <span class="sidebar-day">{lesson.dayLabel}</span>
          <span class="sidebar-lesson-title">{lesson.title}</span>
        </a>
      ))}
    </div>
  ))}
</nav>

<style>
.sidebar-progress-wrap {
  padding: 0.75rem 1.25rem 1.25rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 0.5rem;
}

.sidebar-progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: var(--color-text-muted);
  margin-bottom: 0.4rem;
}

.sidebar-pct {
  font-weight: 700;
  color: var(--color-primary);
}

.sidebar-progress-track {
  height: 6px;
  background: var(--color-border);
  border-radius: 999px;
  overflow: hidden;
}

.sidebar-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  border-radius: 999px;
  transition: width 0.4s ease;
}

.sidebar-lesson-title {
  font-size: 0.82rem;
  line-height: 1.35;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
</style>

<script>
  function initProgress() {
    let progress: Record<string, boolean> = {};
    try {
      progress = JSON.parse(localStorage.getItem('progress') || '{}');
    } catch(e) {}

    const totalEl = document.querySelector('[data-total]') as HTMLElement | null;
    const totalLessons = totalEl ? Number(totalEl.dataset.total) : 24;
    const completed = Object.values(progress).filter(Boolean).length;
    const pct = Math.round((completed / totalLessons) * 100);

    // 진행률 업데이트
    ['sidebarPct', 'mobilePct'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = pct + '%';
    });
    ['sidebarProgressFill', 'mobileProgressFill'].forEach(id => {
      const el = document.getElementById(id) as HTMLElement | null;
      if (el) el.style.width = pct + '%';
    });

    // 체크박스 상태 적용
    document.querySelectorAll('[data-check]').forEach(el => {
      const id = (el as HTMLElement).dataset.check!;
      if (progress[id]) el.classList.add('done');
      else el.classList.remove('done');
    });

    // 완료된 레슨 링크에 클래스
    document.querySelectorAll('[data-lesson-id]').forEach(el => {
      const id = (el as HTMLElement).dataset.lessonId!;
      if (progress[id]) el.classList.add('completed-lesson');
    });
  }

  // 체크박스 클릭 이벤트
  document.querySelectorAll('[data-check]').forEach(el => {
    const handler = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const id = (el as HTMLElement).dataset.check!;
      let progress: Record<string, boolean> = {};
      try { progress = JSON.parse(localStorage.getItem('progress') || '{}'); } catch(e) {}
      progress[id] = !progress[id];
      try { localStorage.setItem('progress', JSON.stringify(progress)); } catch(e) {}
      initProgress();
    };
    el.addEventListener('click', handler);
    el.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === ' ' || (e as KeyboardEvent).key === 'Enter') handler(e);
    });
  });

  initProgress();
  window.addEventListener('progressUpdated', initProgress);
</script>
