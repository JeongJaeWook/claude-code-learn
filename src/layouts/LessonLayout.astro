---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import SubsectionTOC from '../components/SubsectionTOC.astro';
import LessonNav from '../components/LessonNav.astro';
import NotePanel from '../components/NotePanel';
import type { Lesson } from '../data/curriculum';
import { weeks } from '../data/curriculum';
import '../styles/lesson.css';
import '../styles/note.css';

export interface Props {
  lesson: Lesson;
}
const { lesson } = Astro.props;
const weekColors = ['week1', 'week2', 'week3', 'week4'];
const weekColor = weekColors[lesson.week - 1];
const weekTitle = weeks.find(w => w.number === lesson.week)?.title ?? '';
---

<BaseLayout title={lesson.title}>
  <div class="page-wrapper">
    <Header showMobileMenu={true} />

    <div class="content-wrapper">
      <!-- 데스크톱 사이드바 -->
      <Sidebar currentSlug={lesson.slug} />

      <!-- 메인 콘텐츠 -->
      <main class="lesson-main">
        <div class="lesson-header">
          <div class="lesson-meta">
            <span class={`badge badge-${weekColor}`}>{lesson.week}주차</span>
            <span class="lesson-week-label">{weekTitle}</span>
            <span class="lesson-day-label">{lesson.dayLabel}요일</span>
          </div>
          <h1 class="lesson-title">{lesson.title}</h1>
          <button
            class="lesson-complete-btn"
            id="completeBtn"
            data-lesson-id={lesson.id}
          >
            <span class="btn-icon">○</span>
            <span class="btn-label">완료로 표시</span>
          </button>
        </div>

        <div class="lesson-content">
          <slot />
        </div>

        <!-- 메모 패널 -->
        <NotePanel lessonId={lesson.id} client:only="react" />

        <LessonNav prev={lesson.prev} next={lesson.next} />
      </main>

      <!-- 우측 TOC -->
      <SubsectionTOC subsections={lesson.subsections} />
    </div>
  </div>

  <!-- 모바일 사이드바 오버레이 -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <Sidebar currentSlug={lesson.slug} isMobile={true} />
</BaseLayout>

<style>
  /* lesson.css는 global로 import되어야 하므로 BaseLayout slot 대신 직접 link */
</style>

<script>
  // 완료 버튼
  const btn = document.getElementById('completeBtn') as HTMLButtonElement | null;
  const lessonId = btn?.dataset.lessonId;

  function updateCompleteBtn() {
    if (!btn || !lessonId) return;
    let progress: Record<string, boolean> = {};
    try { progress = JSON.parse(localStorage.getItem('progress') || '{}'); } catch(e) {}
    const done = !!progress[lessonId];
    btn.classList.toggle('completed', done);
    const icon = btn.querySelector('.btn-icon');
    const label = btn.querySelector('.btn-label');
    if (icon) icon.textContent = done ? '✓' : '○';
    if (label) label.textContent = done ? '완료됨' : '완료로 표시';
  }

  btn?.addEventListener('click', () => {
    if (!lessonId) return;
    let progress: Record<string, boolean> = {};
    try { progress = JSON.parse(localStorage.getItem('progress') || '{}'); } catch(e) {}
    progress[lessonId] = !progress[lessonId];
    try { localStorage.setItem('progress', JSON.stringify(progress)); } catch(e) {}
    updateCompleteBtn();
    // 사이드바 진행률도 업데이트 (커스텀 이벤트)
    window.dispatchEvent(new Event('progressUpdated'));
  });

  updateCompleteBtn();

  // 모바일 사이드바 토글
  const mobileBtn = document.getElementById('mobileMenuBtn');
  const overlay = document.getElementById('sidebarOverlay');
  const mobileSidebar = document.getElementById('mobileSidebar');

  mobileBtn?.addEventListener('click', () => {
    mobileSidebar?.classList.toggle('open');
    overlay?.classList.toggle('open');
  });

  overlay?.addEventListener('click', () => {
    mobileSidebar?.classList.remove('open');
    overlay?.classList.remove('open');
  });
</script>
